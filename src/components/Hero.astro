---
import DevilFruit from './DevilFruit.astro';
import RedHairFruit from './RedHairFruit.astro';
import NikaFruit from './NikaFruit.astro';
import ShanksIllustration from './ShanksIllustration.astro';
---

<section class="hero-section" aria-labelledby="hero-title">
  <div class="haki-field" aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
  </div>

  <div class="hero-grid">
    <div class="hero-copy reveal">
      <button class="mode-switch" type="button" data-mode-toggle>
        <span class="mode-option" data-mode="reality">REALITY</span>
        <span class="mode-sep" aria-hidden="true">/</span>
        <span class="mode-option" data-mode="red-hair">RED HAIR MODE</span>
        <span class="mode-sep" aria-hidden="true">/</span>
        <span class="mode-option" data-mode="gear-5">GEAR 5</span>
      </button>
      <p class="local-time">MADRID LOCAL TIME · SHIPPING UNTIL THE LOG POSE BREAKS</p>

      <h1 id="hero-title">
        VALENTIN<br />
        GONZALEZ
      </h1>

      <div class="hero-roles" aria-label="Roles">
        <span>SOFTWARE ENGINEER</span>
        <span>FRONTEND PIRATE</span>
        <span>HAKI-DRIVEN BUILDER</span>
      </div>

      <p class="hero-lead">
        I build web apps with clean hands and chaotic energy. Tres años peleando con interfaces,
        product bugs y deadlines; actualmente en <strong>EYSA</strong> moviendo la app
        <strong>MOWIZ</strong>.
      </p>

      <div class="devil-note" aria-label="Devil fruit inspired detail">
        <div class="devil-note-fruit">
          <div class="fruit-mode reality-fruit"><DevilFruit /></div>
          <div class="fruit-mode redhair-fruit"><RedHairFruit /></div>
          <div class="fruit-mode nika-fruit"><NikaFruit /></div>
        </div>
        <p class="fruit-label reality-label">AKUMA NO MI DETAIL UNLOCKED · NO SWIMMING, ONLY SHIPPING</p>
        <p class="fruit-label redhair-label">RED HAIR PIRATES · CONQUEROR'S SAKE</p>
        <p class="fruit-label nika-label">HITO HITO NO MI · MODEL: NIKA · THE DAWN IS COMING</p>
      </div>

      <div class="hero-actions">
        <a href="#experience" class="red-button">View bounty</a>
        <a href="#contact" class="ghost-button">Send den den</a>
      </div>
    </div>

    <aside class="wanted-card reveal" aria-label="Shanks inspired identity mark">
      <div class="conqueror-burst" aria-hidden="true"></div>
      <div class="wanted-top">WANTED</div>
      <div class="wanted-mark">
        <ShanksIllustration />
      </div>
      <div class="wanted-bottom">
        <span>DEADLINE OR ALIVE</span>
        <strong>฿ 3 YEARS XP</strong>
      </div>
    </aside>
  </div>

  <div class="hero-marquee" aria-hidden="true">
    <span>NO BUG LEFT BEHIND / RED FORCE STACK / SHIP IT BEFORE THE GRAND LINE /</span>
  </div>
</section>

<style>
  .hero-section {
    min-height: 100vh;
    padding: clamp(7rem, 12vw, 10rem) 1rem 3rem;
    display: grid;
    align-items: center;
    overflow: hidden;
  }

  .haki-field {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
  }

  .haki-field span {
    position: absolute;
    width: clamp(13rem, 28vw, 30rem);
    aspect-ratio: 1;
    border: 2px solid rgba(181, 21, 34, 0.22);
    border-radius: 50%;
    box-shadow:
      0 0 0 1.2rem rgba(181, 21, 34, 0.05),
      inset 0 0 4rem rgba(181, 21, 34, 0.08);
  }

  .haki-field span:nth-child(1) {
    top: 13%;
    right: 8%;
    --haki-transform: scale(1);
  }

  .haki-field span:nth-child(2) {
    top: 21%;
    right: 17%;
    transform: rotate(16deg) scale(0.72);
    --haki-transform: rotate(16deg) scale(0.72);
  }

  .haki-field span:nth-child(3) {
    bottom: 18%;
    left: 6%;
    transform: scale(0.58);
    --haki-transform: scale(0.58);
  }

  .hero-grid {
    width: min(1180px, 100%);
    margin-inline: auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 0.72fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }

  .local-time {
    margin-bottom: 1.5rem;
    color: var(--muted);
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .mode-switch {
    display: inline-flex;
    align-items: center;
    gap: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--red-dark);
    margin-bottom: 1.25rem;
  }

  .mode-switch::before {
    content: '';
    display: block;
    width: 2.5rem;
    height: 2px;
    background: var(--red);
    margin-right: 0.7rem;
    flex-shrink: 0;
  }

  .mode-option {
    position: relative;
    display: inline-flex;
    align-items: center;
    min-height: 1.8rem;
    padding: 0 0.5rem;
    border: 2px solid transparent;
  }

  .mode-sep {
    display: inline-flex;
    align-items: center;
    padding: 0 0.1rem;
    opacity: 0.3;
    color: var(--red-dark);
    font-weight: 500;
  }

  :global(body.red-hair-mode) .mode-sep {
    color: #ff5a67;
  }

  :global(body.gear-5-mode) .mode-sep {
    color: #a855f7;
  }

  .mode-switch[data-active-mode='reality'] .mode-option[data-mode='reality'],
  .mode-switch[data-active-mode='red-hair'] .mode-option[data-mode='red-hair'],
  .mode-switch[data-active-mode='gear-5'] .mode-option[data-mode='gear-5'] {
    border-color: currentColor;
    background: rgba(181, 21, 34, 0.12);
  }

  :global(body.red-hair-mode) .mode-switch {
    color: #ff5a67;
    text-shadow: 0 0 18px rgba(255, 31, 56, 0.8);
  }

  :global(body.red-hair-mode) .mode-switch[data-active-mode='red-hair'] .mode-option[data-mode='red-hair'] {
    background: rgba(255, 31, 56, 0.22);
    box-shadow: 0 0 22px rgba(255, 31, 56, 0.55);
  }

  :global(body.gear-5-mode) .mode-switch {
    color: #a855f7;
    text-shadow: 0 0 18px rgba(168, 85, 247, 0.8);
  }

  :global(body.gear-5-mode) .mode-switch[data-active-mode='gear-5'] .mode-option[data-mode='gear-5'] {
    background: rgba(168, 85, 247, 0.2);
    box-shadow: 0 0 22px rgba(168, 85, 247, 0.5);
  }

  h1 {
    max-width: 100%;
    font-size: clamp(3.6rem, 8.5vw, 7.2rem);
    font-weight: 900;
  }

  .hero-roles {
    display: grid;
    gap: 0.25rem;
    margin-block: 1.35rem 1.7rem;
    color: var(--red);
    font-size: clamp(1.1rem, 2.5vw, 2rem);
    font-weight: 900;
    line-height: 1;
    text-transform: uppercase;
  }

  .hero-lead {
    max-width: 44rem;
    color: var(--smoke);
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    font-weight: 700;
  }

  .hero-lead strong {
    color: var(--red-dark);
  }

  .devil-note {
    display: grid;
    grid-template-columns: 4.5rem minmax(0, 22rem);
    gap: 0.85rem;
    align-items: center;
    margin-top: 1.5rem;
  }

  .devil-note-fruit {
    aspect-ratio: 1;
    transform: rotate(-8deg);
    position: relative;
  }

  .devil-note-fruit .fruit-mode {
    position: absolute;
    inset: 0;
  }

  .devil-note-fruit .reality-fruit {
    filter: drop-shadow(5px 5px 0 rgba(18, 13, 12, 0.9));
  }

  .devil-note-fruit .redhair-fruit {
    filter: drop-shadow(5px 5px 0 rgba(255, 31, 56, 0.6));
  }

  .devil-note-fruit .nika-fruit {
    filter: drop-shadow(5px 5px 0 rgba(168, 85, 247, 0.7));
  }

  :global(body.red-hair-mode) .fruit-mode.reality-fruit,
  :global(body.red-hair-mode) .fruit-mode.nika-fruit,
  :global(body.gear-5-mode) .fruit-mode.reality-fruit,
  :global(body.gear-5-mode) .fruit-mode.redhair-fruit,
  :global(body:not(.red-hair-mode):not(.gear-5-mode)) .fruit-mode.redhair-fruit,
  :global(body:not(.red-hair-mode):not(.gear-5-mode)) .fruit-mode.nika-fruit {
    display: none;
  }

  .fruit-label {
    display: none;
    color: var(--red-dark);
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    line-height: 1.25;
    text-transform: uppercase;
  }

  :global(body:not(.red-hair-mode):not(.gear-5-mode)) .fruit-label.reality-label,
  :global(body.red-hair-mode) .fruit-label.redhair-label,
  :global(body.gear-5-mode) .fruit-label.nika-label {
    display: block;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
  }

  .wanted-card {
    position: relative;
    padding: 1rem;
    border: 3px solid var(--ink);
    background:
      linear-gradient(rgba(18, 13, 12, 0.06) 1px, transparent 1px),
      var(--paper);
    background-size: 100% 18px;
    box-shadow: 12px 12px 0 var(--ink);
    transform: rotate(2deg);
  }

  .conqueror-burst {
    position: absolute;
    inset: -3.5rem;
    z-index: -1;
    background:
      conic-gradient(from 9deg, transparent 0 8deg, rgba(181, 21, 34, 0.44) 9deg 10deg, transparent 11deg 38deg),
      radial-gradient(circle, rgba(216, 164, 63, 0.22), transparent 62%);
    opacity: 0.8;
    filter: blur(0.2px);
  }

  :global(body.red-hair-mode) .conqueror-burst {
    inset: -6rem;
    opacity: 1;
    background:
      conic-gradient(from 9deg, transparent 0 5deg, rgba(255, 31, 56, 0.9) 5deg 6deg, transparent 7deg 18deg),
      conic-gradient(from -22deg, transparent 0 10deg, rgba(255, 211, 107, 0.28) 10deg 11deg, transparent 12deg 36deg),
      radial-gradient(circle, rgba(255, 31, 56, 0.42), transparent 61%);
    filter: drop-shadow(0 0 24px rgba(255, 31, 56, 0.72));
  }

  :global(body.gear-5-mode) .conqueror-burst {
    inset: -6rem;
    opacity: 1;
    background:
      conic-gradient(from 9deg, transparent 0 5deg, rgba(168, 85, 247, 0.7) 5deg 6deg, transparent 7deg 18deg),
      conic-gradient(from -22deg, transparent 0 10deg, rgba(251, 191, 36, 0.35) 10deg 11deg, transparent 12deg 36deg),
      radial-gradient(circle, rgba(168, 85, 247, 0.35), transparent 61%);
    filter: drop-shadow(0 0 24px rgba(168, 85, 247, 0.6));
  }

  .wanted-card::before,
  .wanted-card::after {
    content: '';
    position: absolute;
    width: 5rem;
    height: 1.6rem;
    background: rgba(181, 21, 34, 0.82);
    border: 2px solid var(--ink);
  }

  :global(body.gear-5-mode) .wanted-card::before,
  :global(body.gear-5-mode) .wanted-card::after {
    background: rgba(168, 85, 247, 0.7);
  }

  :global(body.red-hair-mode) .wanted-card {
    box-shadow:
      12px 12px 0 #ff1f38,
      0 0 55px rgba(255, 31, 56, 0.38);
  }

  :global(body.gear-5-mode) .wanted-card {
    box-shadow:
      12px 12px 0 #a855f7,
      0 0 55px rgba(168, 85, 247, 0.35);
  }

  .wanted-card::before {
    top: -1rem;
    left: 1.2rem;
    transform: rotate(-9deg);
  }

  .wanted-card::after {
    right: 1rem;
    bottom: -0.9rem;
    transform: rotate(-5deg);
  }

  .wanted-top {
    border-bottom: 3px solid var(--ink);
    padding-bottom: 0.4rem;
    text-align: center;
    font-size: clamp(2.8rem, 8vw, 5.5rem);
    font-weight: 900;
    line-height: 0.82;
  }

  .wanted-mark {
    aspect-ratio: 1;
    margin-block: 1rem;
    border: 2px solid var(--ink);
    background: #201313;
    overflow: hidden;
  }

  .wanted-bottom {
    display: grid;
    gap: 0.35rem;
    border-top: 3px solid var(--ink);
    padding-top: 0.65rem;
    text-align: center;
    font-weight: 900;
    text-transform: uppercase;
  }

  .wanted-bottom span {
    color: var(--red-dark);
    font-size: 0.78rem;
    letter-spacing: 0.16em;
  }

  .wanted-bottom strong {
    font-size: clamp(1.2rem, 4vw, 2rem);
  }

  .hero-marquee {
    width: min(1180px, 100%);
    margin: clamp(2.5rem, 5vw, 4rem) auto 0;
    border-block: 2px solid var(--ink);
    overflow: hidden;
    color: var(--paper);
    background: var(--ink);
    font-size: clamp(1.5rem, 5vw, 4rem);
    font-weight: 900;
    line-height: 1;
    white-space: nowrap;
  }

  .hero-marquee span {
    display: block;
    padding: 0.5rem 0;
    animation: slideText 20s linear infinite;
  }

  @keyframes slideText {
    to {
      transform: translateX(-55%);
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .wanted-card {
      animation: floatMark 4s ease-in-out infinite alternate;
    }

    .haki-field span {
      animation: hakiPulse 3.6s ease-in-out infinite alternate;
    }

    .haki-field span:nth-child(2) {
      animation-delay: 500ms;
    }

    .haki-field span:nth-child(3) {
      animation-delay: 900ms;
    }
  }

  @keyframes hakiPulse {
    to {
      transform: var(--haki-transform) scale(1.08);
      opacity: 0.45;
    }
  }

  @media (max-width: 860px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .wanted-card {
      max-width: 26rem;
      margin-inline: auto;
      transform: none;
    }
  }

  @media (max-width: 520px) {
    .hero-section {
      padding-top: 6.5rem;
    }

    h1 {
      font-size: clamp(3.4rem, 19vw, 5rem);
    }

    .devil-note {
      grid-template-columns: 3.8rem 1fr;
    }
  }
</style>
