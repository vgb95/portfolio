<style>
  .nika-fruit {
    display: block;
    width: 100%;
    height: 100%;
  }

  .fruit-body {
    filter: drop-shadow(0 0 14px rgba(109, 40, 217, 0.5)) drop-shadow(0 0 35px rgba(109, 40, 217, 0.25));
  }

  .nika-swirl {
    filter: drop-shadow(0 0 6px rgba(109, 40, 217, 0.35));
  }

  @media (prefers-reduced-motion: reduce) {
    .nika-swirl path,
    .cloud-puffs ellipse,
    .steam-bursts circle,
    .steam-trails path,
    .flame-auras path,
    .fruit-stem,
    .fruit-body,
    circle {
      animation: none !important;
    }
  }
</style>
