    <circle cx="100" cy="100" r="100" fill="url(#steamGlow)" opacity="0">
      <animate attributeName="r" values="60;130;60" dur="5s" repeatCount="indefinite" begin="2s" />
      <animate attributeName="opacity" values="0;0.2;0" dur="5s" repeatCount="indefinite" begin="2s" />
    </circle>
  </g>

  <circle cx="100" cy="100" r="90" fill="url(#nikaGlow)">
