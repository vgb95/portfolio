---
const projects = [
  { id: '001', title: 'URL SHORTENER', status: 'PLACEHOLDER BOUNTY', stack: ['React', 'Node.js', 'MongoDB'] },
  { id: '002', title: 'TASK MANAGER', status: 'WAITING FOR CREW', stack: ['Next.js', 'Firebase', 'TypeScript'] },
  { id: '003', title: 'WEATHER APP', status: 'CALM BELT DRAFT', stack: ['React', 'REST API', 'Tailwind'] },
  { id: '004', title: 'E-COMMERCE DASH', status: 'MERCHANT ARC SOON', stack: ['React', 'GraphQL', 'PostgreSQL'] },
];
---

<section id="projects" class="projects-section">
  <div class="section-shell">
    <div class="projects-title">
      <div class="section-kicker">/03 Builds</div>
      <h2>EMPTY SLOTS, REAL INTENT.</h2>
      <p>
        These are docking bays for personal projects. No fake flex, just marked space for the next ships.
      </p>
    </div>

    <div class="project-grid">
      {projects.map((project) => (
        <a href="#" class="project-card hard-panel" aria-label={`${project.title} coming soon`}>
          <span class="project-id">{project.id}</span>
          <h3>{project.title}</h3>
          <p>{project.status}</p>
          <div>
            {project.stack.map((item) => <span>{item}</span>)}
          </div>
          <strong>COMING SOON -></strong>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .projects-title {
    display: grid;
    grid-template-columns: 1fr minmax(18rem, 0.6fr);
    gap: 2rem;
    align-items: end;
    margin-bottom: 2rem;
  }

  h2 {
    max-width: 11ch;
    font-size: clamp(3rem, 8vw, 7rem);
    font-weight: 900;
  }

  .projects-title p {
    color: var(--muted);
    font-size: 1.05rem;
    font-weight: 800;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .project-card {
    position: relative;
    display: grid;
    min-height: 19rem;
    padding: 1.2rem;
    color: var(--ink);
    text-decoration: none;
    overflow: hidden;
  }

  .project-card::after {
    content: '';
    position: absolute;
    inset: auto -2rem -2.2rem auto;
    width: 9rem;
    aspect-ratio: 1;
    border: 2px solid var(--ink);
    background: var(--red);
    transform: rotate(18deg);
  }

  .project-card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 12px 12px 0 var(--ink);
  }

  .project-id {
    color: var(--red);
    font-size: 0.9rem;
    font-weight: 900;
    letter-spacing: 0.14em;
  }

  h3 {
    align-self: end;
    max-width: 8ch;
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 900;
    line-height: 0.9;
  }

  .project-card p,
  .project-card strong,
  .project-card div span {
    font-size: 0.76rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .project-card p {
    color: var(--red-dark);
  }

  .project-card div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-block: 1rem;
  }

  .project-card div span {
    border: 2px solid var(--ink);
    background: var(--ink);
    color: var(--paper);
    padding: 0.45rem 0.55rem;
  }

  .project-card strong {
    align-self: end;
  }

  @media (max-width: 820px) {
    .projects-title,
    .project-grid {
      grid-template-columns: 1fr;
    }

    .project-card {
      min-height: 16rem;
    }
  }
</style>
