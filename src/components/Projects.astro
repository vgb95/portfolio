---
---

<section id="projects" class="py-20 px-4 sm:px-6 lg:px-8 bg-white">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-4xl md:text-5xl font-bold mb-16 text-center">Proyectos</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Proyecto 1 -->
      <div class="group relative bg-gradient-to-br from-gray-50 to-gray-100 rounded-xl p-8 border border-gray-200 hover:border-blue-400 transition hover:shadow-lg">
        <div class="absolute top-0 right-0 w-32 h-32 bg-blue-100 rounded-full blur-3xl opacity-0 group-hover:opacity-50 transition -z-10"></div>
        
        <h3 class="text-2xl font-bold mb-3">URL Shortener</h3>
        <p class="text-gray-600 mb-4">
          Aplicación web para acortar URLs con análisis de clics y estadísticas. 
          Interfaz limpia y rápida.
        </p>
        
        <div class="flex flex-wrap gap-2 mb-6">
          <span class="px-3 py-1 bg-blue-100 text-blue-700 text-sm rounded-full">React</span>
          <span class="px-3 py-1 bg-blue-100 text-blue-700 text-sm rounded-full">Node.js</span>
          <span class="px-3 py-1 bg-blue-100 text-blue-700 text-sm rounded-full">MongoDB</span>
        </div>
        
        <a href="#" class="inline-block text-blue-600 font-semibold hover:text-blue-700 transition">
          Próximamente →
        </a>
      </div>

      <!-- Proyecto 2 -->
      <div class="group relative bg-gradient-to-br from-gray-50 to-gray-100 rounded-xl p-8 border border-gray-200 hover:border-blue-400 transition hover:shadow-lg">
        <div class="absolute top-0 right-0 w-32 h-32 bg-blue-100 rounded-full blur-3xl opacity-0 group-hover:opacity-50 transition -z-10"></div>
        
        <h3 class="text-2xl font-bold mb-3">Task Manager</h3>
        <p class="text-gray-600 mb-4">
          Gestor de tareas colaborativo con sincronización en tiempo real.
          Diseño intuitivo y funcionalidades avanzadas.
        </p>
        
        <div class="flex flex-wrap gap-2 mb-6">
          <span class="px-3 py-1 bg-purple-100 text-purple-700 text-sm rounded-full">Next.js</span>
          <span class="px-3 py-1 bg-purple-100 text-purple-700 text-sm rounded-full">Firebase</span>
          <span class="px-3 py-1 bg-purple-100 text-purple-700 text-sm rounded-full">TypeScript</span>
        </div>
        
        <a href="#" class="inline-block text-purple-600 font-semibold hover:text-purple-700 transition">
          Próximamente →
        </a>
      </div>

      <!-- Proyecto 3 -->
      <div class="group relative bg-gradient-to-br from-gray-50 to-gray-100 rounded-xl p-8 border border-gray-200 hover:border-blue-400 transition hover:shadow-lg">
        <div class="absolute top-0 right-0 w-32 h-32 bg-blue-100 rounded-full blur-3xl opacity-0 group-hover:opacity-50 transition -z-10"></div>
        
        <h3 class="text-2xl font-bold mb-3">Weather App</h3>
        <p class="text-gray-600 mb-4">
          Aplicación de clima con pronósticos detallados y visualización elegante.
          Datos en tiempo real de múltiples ciudades.
        </p>
        
        <div class="flex flex-wrap gap-2 mb-6">
          <span class="px-3 py-1 bg-green-100 text-green-700 text-sm rounded-full">React</span>
          <span class="px-3 py-1 bg-green-100 text-green-700 text-sm rounded-full">API REST</span>
          <span class="px-3 py-1 bg-green-100 text-green-700 text-sm rounded-full">Tailwind</span>
        </div>
        
        <a href="#" class="inline-block text-green-600 font-semibold hover:text-green-700 transition">
          Próximamente →
        </a>
      </div>

      <!-- Proyecto 4 -->
      <div class="group relative bg-gradient-to-br from-gray-50 to-gray-100 rounded-xl p-8 border border-gray-200 hover:border-blue-400 transition hover:shadow-lg">
        <div class="absolute top-0 right-0 w-32 h-32 bg-blue-100 rounded-full blur-3xl opacity-0 group-hover:opacity-50 transition -z-10"></div>
        
        <h3 class="text-2xl font-bold mb-3">E-Commerce Dashboard</h3>
        <p class="text-gray-600 mb-4">
          Dashboard administrativo para gestión de tienda online.
          Análisis de ventas, inventario y usuarios.
        </p>
        
        <div class="flex flex-wrap gap-2 mb-6">
          <span class="px-3 py-1 bg-red-100 text-red-700 text-sm rounded-full">React</span>
          <span class="px-3 py-1 bg-red-100 text-red-700 text-sm rounded-full">GraphQL</span>
          <span class="px-3 py-1 bg-red-100 text-red-700 text-sm rounded-full">PostgreSQL</span>
        </div>
        
        <a href="#" class="inline-block text-red-600 font-semibold hover:text-red-700 transition">
          Próximamente →
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  section {
    animation: slideUp 0.8s ease-in-out;
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
