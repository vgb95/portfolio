---
// Componente SVG de Shanks inspirado en el estilo de luffy.sh
---

<svg
  viewBox="0 0 400 400"
  xmlns="http://www.w3.org/2000/svg"
  class="w-full h-full"
>
  <!-- Define filtro halftone -->
  <defs>
    <filter id="halftone">
      <feTurbulence baseFrequency="0.02" numOctaves="3" result="noise" />
      <feDisplacementMap in="SourceGraphic" in2="noise" scale="2" />
    </filter>
    
    <linearGradient id="skinGradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f4a460;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#d2691e;stop-opacity:1" />
    </linearGradient>
    
    <linearGradient id="hairGradient" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#8B4513;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#654321;stop-opacity:1" />
    </linearGradient>
  </defs>

  <!-- Fondo del círculo -->
  <circle cx="200" cy="200" r="195" fill="#f0f0f0" stroke="#000" stroke-width="2"/>

  <!-- Cabello (estilo Shanks) -->
  <path
    d="M 100 150 Q 80 120 120 80 Q 200 20 280 80 Q 320 120 300 150 Z"
    fill="url(#hairGradient)"
    filter="url(#halftone)"
  />
  
  <!-- Pelos adicionales para darle volumen -->
  <path
    d="M 110 140 Q 90 110 100 70"
    stroke="#654321"
    stroke-width="8"
    fill="none"
    stroke-linecap="round"
  />
  
  <path
    d="M 290 140 Q 310 110 300 70"
    stroke="#654321"
    stroke-width="8"
    fill="none"
    stroke-linecap="round"
  />

  <!-- Cicatriz característica de Shanks (sobre el ojo izquierdo) -->
  <path
    d="M 140 160 L 160 180 L 150 190"
    stroke="#8B0000"
    stroke-width="4"
    fill="none"
    stroke-linecap="round"
    stroke-linejoin="round"
  />

  <!-- Cara -->
  <circle cx="200" cy="200" r="90" fill="url(#skinGradient)" filter="url(#halftone)" />

  <!-- Ojos -->
  <!-- Ojo derecho (con cicatriz) -->
  <ellipse cx="160" cy="180" rx="12" ry="18" fill="#fff" />
  <circle cx="160" cy="185" r="8" fill="#000" />
  <circle cx="162" cy="183" r="3" fill="#fff" />
  
  <!-- Ojo izquierdo (oculto por la cicatriz, solo visible parcialmente) -->
  <ellipse cx="240" cy="180" rx="12" ry="18" fill="#fff" />
  <circle cx="240" cy="185" r="8" fill="#000" />
  <circle cx="242" cy="183" r="3" fill="#fff" />

  <!-- Nariz -->
  <path
    d="M 200 190 L 200 220"
    stroke="#d2691e"
    stroke-width="3"
    stroke-linecap="round"
  />

  <!-- Sonrisa característica -->
  <path
    d="M 170 240 Q 200 260 230 240"
    stroke="#8B4513"
    stroke-width="4"
    fill="none"
    stroke-linecap="round"
  />

  <!-- Brazo izquierdo (missing arm side) - mostrar la ausencia -->
  <text x="130" y="300" font-size="24" fill="#999" text-anchor="middle">🏴‍☠️</text>

  <!-- Cabello rojo distintivo -->
  <path
    d="M 120 140 Q 110 180 140 220"
    stroke="#DC143C"
    stroke-width="6"
    fill="none"
    stroke-linecap="round"
    opacity="0.7"
  />
  
  <path
    d="M 280 140 Q 290 180 260 220"
    stroke="#DC143C"
    stroke-width="6"
    fill="none"
    stroke-linecap="round"
    opacity="0.7"
  />

  <!-- Línea decorativa inferior -->
  <line x1="100" y1="330" x2="300" y2="330" stroke="#000" stroke-width="1" opacity="0.2" />
  
  <!-- Texto "Shanks" -->
  <text 
    x="200" 
    y="360" 
    font-family="Arial, sans-serif" 
    font-size="20" 
    font-weight="bold"
    text-anchor="middle"
    fill="#000"
  >
    SHANKS
  </text>
</svg>

<style>
  svg {
    filter: drop-shadow(0 4px 6px rgba(0, 0, 0, 0.1));
  }
</style>
