<svg
  viewBox="0 0 400 400"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-labelledby="shanks-title shanks-desc"
>
  <title id="shanks-title">Abstract Shanks inspired mark</title>
  <desc id="shanks-desc">A red and black graphic mark inspired by Shanks, with scar cuts, cloak shapes, and haki rings.</desc>
  <defs>
    <pattern id="grain" width="10" height="10" patternUnits="userSpaceOnUse">
      <circle cx="1" cy="1" r="1" fill="#f4ead2" opacity="0.2" />
      <circle cx="7" cy="5" r="1" fill="#f4ead2" opacity="0.14" />
      <circle cx="4" cy="9" r="0.8" fill="#f4ead2" opacity="0.2" />
    </pattern>
    <linearGradient id="redSlash" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#e0202c" />
      <stop offset="55%" stop-color="#b51522" />
      <stop offset="100%" stop-color="#6d0710" />
    </linearGradient>
  </defs>

  <rect width="400" height="400" fill="#120d0c" />
  <rect width="400" height="400" fill="url(#grain)" />

  <g class="haki-rings" fill="none" stroke="#f4ead2" stroke-width="2" opacity="0.35">
    <circle cx="200" cy="205" r="154" />
    <circle cx="200" cy="205" r="112" />
    <circle cx="200" cy="205" r="72" />
  </g>

  <path d="M72 333 C94 225 116 127 200 57 C284 127 306 225 328 333 Z" fill="#f4ead2" />
  <path d="M92 333 C112 245 134 155 200 89 C266 155 288 245 308 333 Z" fill="#b51522" />
  <path d="M130 333 C148 237 166 179 200 129 C234 179 252 237 270 333 Z" fill="#120d0c" />

  <path class="slash slash-one" d="M111 97 L154 89 L289 328 L245 336 Z" fill="url(#redSlash)" />
  <path class="slash slash-two" d="M197 59 L237 75 L165 340 L125 324 Z" fill="url(#redSlash)" />
  <path class="slash slash-three" d="M277 102 L314 129 L99 305 L67 275 Z" fill="url(#redSlash)" />

  <g stroke="#f4ead2" stroke-linecap="square" stroke-width="8">
    <path d="M116 212 H284" />
    <path d="M200 108 V318" />
  </g>

  <g fill="#120d0c">
    <circle cx="153" cy="190" r="11" />
    <circle cx="247" cy="190" r="11" />
  </g>

  <path d="M153 261 C176 282 224 282 247 261" fill="none" stroke="#120d0c" stroke-width="8" stroke-linecap="square" />

  <text x="200" y="374" text-anchor="middle" fill="#f4ead2" font-family="Inter, Arial, sans-serif" font-size="22" font-weight="900" letter-spacing="5">
    RED HAIR
  </text>
</svg>

<style>
  svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .slash {
    mix-blend-mode: multiply;
    transform-origin: 200px 200px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .haki-rings {
      animation: pulseHaki 2.8s ease-in-out infinite alternate;
    }

    .slash-one {
      animation: scarShift 3.2s ease-in-out infinite alternate;
    }
  }

  @keyframes pulseHaki {
    to {
      opacity: 0.62;
      transform: scale(1.025);
    }
  }

  @keyframes scarShift {
    to {
      transform: translateX(4px);
    }
  }
</style>
