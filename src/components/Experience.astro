<section id="experience" class="py-20 px-4 sm:px-6 lg:px-8 bg-gray-50">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-4xl md:text-5xl font-bold mb-16 text-center">Experiencia</h2>
    
    <div class="space-y-12">
      <!-- EYSA - Actual -->
      <div class="relative pl-8 border-l-4 border-blue-600">
        <div class="absolute -left-3 top-0 w-4 h-4 bg-blue-600 rounded-full"></div>
        
        <div>
          <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-2">
            <h3 class="text-2xl font-bold">Software Engineer - EYSA</h3>
            <span class="text-sm text-gray-600 font-medium">Abril 2026 - Actualidad</span>
          </div>
          
          <p class="text-lg text-blue-600 font-semibold mb-4">App MOWIZ</p>
          
          <ul class="space-y-2 text-gray-700 list-disc list-inside">
            <li>Desarrollo de features en la aplicación MOWIZ</li>
            <li>Colaboración con equipos cross-functional</li>
            <li>Mejora continua del código y arquitectura</li>
          </ul>
        </div>
      </div>

      <!-- NTT DATA -->
      <div class="relative pl-8 border-l-4 border-gray-300">
        <div class="absolute -left-3 top-0 w-4 h-4 bg-gray-400 rounded-full"></div>
        
        <div>
          <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-2">
            <h3 class="text-2xl font-bold">Software Engineer - NTT DATA</h3>
            <span class="text-sm text-gray-600 font-medium">Marzo 2023 - Abril 2026</span>
          </div>
          
          <p class="text-lg text-gray-600 font-semibold mb-4">Proyecto: Web comerciales Iberdrola</p>
          
          <ul class="space-y-2 text-gray-700 list-disc list-inside">
            <li>Desarrollo de aplicaciones web para portales comerciales de Iberdrola</li>
            <li>Implementación de features frontend y backend</li>
            <li>Trabajo con tecnologías modernas del ecosistema web</li>
            <li>Mejora de performance y experiencia del usuario</li>
            <li>Colaboración en equipo y code reviews</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  section {
    animation: slideUp 0.8s ease-in-out;
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
