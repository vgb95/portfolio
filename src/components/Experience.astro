---
const jobs = [
  {
    number: '01',
    role: 'Software Engineer',
    company: 'EYSA',
    date: 'APR 2026 - CURRENT',
    tag: 'MOWIZ APP',
    lines: ['Shipping product features', 'Cross-functional squad work', 'Code quality without killing velocity'],
  },
  {
    number: '02',
    role: 'Software Engineer',
    company: 'NTT DATA',
    date: 'MAR 2023 - APR 2026',
    tag: 'IBERDROLA COMMERCIAL WEBS',
    lines: ['Frontend and backend delivery', 'Performance and UX improvements', 'Reviews, bugs, releases, repeat'],
  },
];
---

<section id="experience" class="experience-section">
  <div class="section-shell">
    <div class="experience-header">
      <div>
        <div class="section-kicker">/02 Bounties</div>
        <h2>PROOF OF WORK, NO FILLER ARC.</h2>
      </div>
      <p>
        Current bounty: turning product chaos into web features that survive real users.
        Sin drama. Bueno, a veces con un poco.
      </p>
    </div>

    <div class="job-list">
      {jobs.map((job) => (
        <article class="job-row">
          <div class="job-number">{job.number}</div>
          <div>
            <h3>{job.role} · {job.company}</h3>
            <p class="job-tag">{job.tag}</p>
          </div>
          <div class="job-date">{job.date}</div>
          <ul>
            {job.lines.map((line) => <li>{line}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .experience-section {
    color: var(--paper);
    background:
      linear-gradient(135deg, rgba(181, 21, 34, 0.22), transparent 36rem),
      var(--ink);
  }

  :global(body.red-hair-mode) .experience-section {
    color: #f7ead0;
    background:
      radial-gradient(circle at 22% 16%, rgba(255, 31, 56, 0.34), transparent 22rem),
      repeating-conic-gradient(from 30deg at 70% 30%, rgba(255, 31, 56, 0.16) 0 2deg, transparent 2deg 18deg),
      #090304;
  }

  :global(body.gear-5-mode) .experience-section {
    color: #faf5ff;
    background:
      radial-gradient(circle at 30% 20%, rgba(168, 85, 247, 0.2), transparent 22rem),
      repeating-conic-gradient(from 30deg at 70% 30%, rgba(168, 85, 247, 0.1) 0 2deg, transparent 2deg 18deg),
      #1e1b4b;
  }

  .experience-section .section-kicker {
    color: var(--gold);
  }

  .experience-section .section-kicker::before {
    background: var(--gold);
  }

  .experience-header {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: end;
    margin-bottom: 2rem;
  }

  h2 {
    max-width: 11ch;
    font-size: clamp(3rem, 8vw, 7rem);
    font-weight: 900;
  }

  .experience-header p {
    border-left: 3px solid var(--red);
    padding-left: 1rem;
    color: #ead8b7;
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 800;
  }

  :global(body.gear-5-mode) .experience-header p {
    color: #c4b5fd;
  }

  .job-list {
    border-top: 2px solid rgba(244, 234, 210, 0.35);
  }

  .job-row {
    display: grid;
    grid-template-columns: 4rem minmax(0, 1fr) auto minmax(18rem, 0.75fr);
    gap: 1.5rem;
    align-items: start;
    padding: 1.35rem 0;
    border-bottom: 2px solid rgba(244, 234, 210, 0.35);
  }

  .job-number {
    color: var(--red);
    font-size: 2.4rem;
    font-weight: 900;
    line-height: 1;
  }

  :global(body.gear-5-mode) .job-number {
    color: #a855f7;
  }

  h3 {
    font-size: clamp(1.45rem, 3vw, 2.7rem);
    font-weight: 900;
  }

  .job-tag,
  .job-date,
  li {
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .job-tag {
    margin-top: 0.4rem;
    color: var(--gold);
  }

  .job-date {
    color: #d7c9ab;
    white-space: nowrap;
  }

  ul {
    display: grid;
    gap: 0.45rem;
    list-style: none;
  }

  li::before {
    content: 'x';
    margin-right: 0.55rem;
    color: var(--red);
  }

  :global(body.gear-5-mode) li::before {
    color: #a855f7;
  }

  @media (max-width: 900px) {
    .experience-header,
    .job-row {
      grid-template-columns: 1fr;
    }

    .job-date {
      white-space: normal;
    }
  }
</style>
