---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';

interface Props {
  title?: string;
}

const { title = "VGB95" } = Astro.props;
const baseUrl = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Portfolio Valentín González: Software Engineer, web builder." />
    <link rel="icon" type="image/png" sizes="32x32" href={`${baseUrl}favicon-32.png`} />
    <link rel="icon" type="image/png" sizes="16x16" href={`${baseUrl}favicon-16.png`} />
    <link rel="shortcut icon" href={`${baseUrl}favicon.ico`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${baseUrl}apple-touch-icon.png`} />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <Navbar />
    <slot />
    <script>
      const MODES = ['reality', 'red-hair', 'gear-5'];

      const readStoredMode = () => {
        try {
          return window.localStorage?.getItem('portfolio-mode');
        } catch {
          return null;
        }
      };

      const writeStoredMode = (mode) => {
        try {
          window.localStorage?.setItem('portfolio-mode', mode);
        } catch {
          // Storage can be unavailable in previews or strict privacy modes.
        }
      };

      const storedMode = readStoredMode();
      const initialMode = MODES.includes(storedMode) ? storedMode : 'reality';

      document.body.classList.toggle('red-hair-mode', initialMode === 'red-hair');
      document.body.classList.toggle('gear-5-mode', initialMode === 'gear-5');

      const syncModeButtons = () => {
        const buttons = document.querySelectorAll('[data-mode-toggle]');
        buttons.forEach((button) => {
          let current;
          if (document.body.classList.contains('gear-5-mode')) {
            current = 'gear-5';
          } else if (document.body.classList.contains('red-hair-mode')) {
            current = 'red-hair';
          } else {
            current = 'reality';
          }
          button.setAttribute('data-active-mode', current);
        });
      };

      syncModeButtons();

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        const button = target.closest('[data-mode-toggle]');
        if (!button) return;

        let current;
        if (document.body.classList.contains('gear-5-mode')) {
          current = 'gear-5';
        } else if (document.body.classList.contains('red-hair-mode')) {
          current = 'red-hair';
        } else {
          current = 'reality';
        }

        const nextIdx = (MODES.indexOf(current) + 1) % MODES.length;
        const next = MODES[nextIdx];

        document.body.classList.remove('red-hair-mode', 'gear-5-mode');
        if (next === 'red-hair') document.body.classList.add('red-hair-mode');
        else if (next === 'gear-5') document.body.classList.add('gear-5-mode');

        writeStoredMode(next);
        syncModeButtons();
      });
    </script>
  </body>
</html>

<style is:global>
</style>
