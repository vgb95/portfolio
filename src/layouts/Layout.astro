---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = "Valentín González - Software Engineer" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Portfolio de Valentín González - Software Engineer con 3 años de experiencia" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg-primary: #ffffff;
    --text-primary: #000000;
    --text-secondary: #666666;
    --accent: #1e40af;
  }
</style>
