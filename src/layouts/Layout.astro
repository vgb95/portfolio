---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';

interface Props {
  title?: string;
}

const { title = "Valentín González -  Software Engineer" } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Portfolio Valentín González: Software Engineer, web builder." />
    <link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <Navbar />
    <slot />
    <script>
      const readStoredMode = () => {
        try {
          return window.localStorage?.getItem('portfolio-mode');
        } catch {
          return null;
        }
      };

      const writeStoredMode = (mode) => {
        try {
          window.localStorage?.setItem('portfolio-mode', mode);
        } catch {
          // Storage can be unavailable in previews or strict privacy modes.
        }
      };

      const storedMode = readStoredMode();
      const prefersRedHair = storedMode === 'red-hair';

      document.body.classList.toggle('red-hair-mode', prefersRedHair);

      const syncModeButtons = () => {
        const buttons = document.querySelectorAll('[data-mode-toggle]');
        buttons.forEach((button) => {
          const isRedHair = document.body.classList.contains('red-hair-mode');
          button.setAttribute('aria-pressed', String(isRedHair));
          button.setAttribute('data-active-mode', isRedHair ? 'red-hair' : 'reality');
        });
      };

      syncModeButtons();

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;

        const button = target.closest('[data-mode-toggle]');
        if (!button) return;

        const isRedHair = document.body.classList.toggle('red-hair-mode');
        writeStoredMode(isRedHair ? 'red-hair' : 'reality');
        syncModeButtons();
      });
    </script>
  </body>
</html>

<style is:global>
</style>
